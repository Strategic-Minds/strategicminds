{
  "project": "strategicminds-client-os",
  "targetRepo": "Strategic-Minds/strategicminds",
  "controlRepo": "Strategic-Minds/AUTO_BUILDER",
  "driveRoot": "V2 MASTER AUTO BUILDER/STRATEGIC MINDS ADVISORY",
  "mode": "preview_only",
  "productionDeploy": "operator_approval_required",
  "siteFramework": "clean_target_pending_build",
  "orchestrator": "auto_builder_vercel_workflow",
  "workflow": {
    "source": "AUTO_BUILDER",
    "transport": "vercel_workflow",
    "cron": "*/5 * * * *",
    "validation": "auto_builder_validation_agent",
    "receipts": "drive_github_vercel"
  },
  "gates": {
    "livePayments": "blocked_until_operator_approval",
    "sms": "queue_only_until_operator_approval",
    "customerMessages": "blocked_until_operator_approval",
    "production": "blocked_until_operator_approval",
    "secrets": "never_commit",
    "legacyRepo": "do_not_use_as_build_target"
  }
}
